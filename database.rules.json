{
  "rules": {
    "events": {
      "$event": {
        "assignments": {
          ".read": true,
          ".write": true,
          "$id": {
            ".validate": "newData.hasChildren(['discord','type','ts'])"
          }
        },
        "history": {
          ".read": true,
          ".write": true
        },
        "archives": {
          ".read": true,
          ".write": true
        }
      }
    },
    "users": {
      ".read": true,
      "$key": {
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['username','salt','hash','iterations'])"
      }
    },
    "admin": {
      ".read": true,
      "owner": {
        ".write": "!data.exists()",
        ".validate": "newData.isString()"
      }
    },
    "cardImages": {
      ".read": true,
      ".write": true,
      "$key": {
        ".validate": "newData.hasChild('img') || newData.hasChild('backImg')",
        "img": { ".validate": "newData.isString()" },
        "backImg": { ".validate": "newData.isString()" },
        "ts": { ".validate": "newData.isNumber()" },
        "by": { ".validate": "newData.isString()" },
        "$other": { ".validate": false }
      }
    },
    "cardImagesStaged": {
      ".read": true,
      ".write": true,
      "$key": {
        ".validate": "newData.hasChild('img') || newData.hasChild('backImg')",
        "img": { ".validate": "newData.isString()" },
        "backImg": { ".validate": "newData.isString()" },
        "ts": { ".validate": "newData.isNumber()" },
        "by": { ".validate": "newData.isString()" },
        "$other": { ".validate": false }
      }
    },
    "cardMeta": {
      ".read": true,
      ".write": true,
      "$key": {
        ".validate": "newData.hasChild('partner')",
        "partner": { ".validate": "newData.isBoolean()" },
        "ts": { ".validate": "newData.isNumber()" },
        "by": { ".validate": "newData.isString()" },
        "$other": { ".validate": false }
      }
    },
    "cardStatus": {
      ".read": true,
      ".write": true,
      "$key": {
        ".validate": "newData.hasChild('state')",
        "state": { ".validate": "newData.isString() && newData.val().matches(/^(pending|pendingRemoval|hidden)$/)" },
        "ts": { ".validate": "newData.isNumber()" },
        "by": { ".validate": "newData.isString()" },
        "$other": { ".validate": false }
      }
    },
    "customCards": {
      ".read": true,
      ".write": true,
      "$key": {
        ".validate": "newData.hasChildren(['name','img'])",
        "name": { ".validate": "newData.isString()" },
        "back": { ".validate": "newData.isString()" },
        "img": { ".validate": "newData.isString()" },
        "backImg": { ".validate": "newData.isString()" },
        "ts": { ".validate": "newData.isNumber()" },
        "by": { ".validate": "newData.isString()" },
        "$other": { ".validate": false }
      }
    }
  }
}
